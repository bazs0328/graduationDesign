# Optional deployer overrides for StudyCompass.
# Ordinary student usage does not require editing this file.
# Start the app first, then fill provider settings in 设置中心 -> 模型接入.

APP_NAME=StudyCompass
DATA_DIR=data
AUTH_SECRET_KEY=
AUTH_TOKEN_TTL_HOURS=72
AUTH_REQUIRE_LOGIN=true
AUTH_ALLOW_LEGACY_USER_ID=false
